# LLM provider selection.
# LLM_PROVIDER: auto | anthropic | groq | google | openai | none
#   - "auto" picks by which key is set (precedence: anthropic > groq > google > openai)
#   - set it explicitly to force one provider and ignore the others
#   - "none" forces deterministic fallback mode (no LLM calls)
LLM_PROVIDER=groq

# Groq (fast, free tier — open models like Llama)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_ORG_ID=
MODEL_NAME=gpt-4o-mini

# Reserved / optional
SERPAPI_KEY=

# Fixed "today" for deterministic deadline math (optional)
DEMO_REFERENCE_DATE=2026-01-05
